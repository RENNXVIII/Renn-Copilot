# Port for renn-copilot's own backend (dashboard + extension talk to this)
PORT=4317

# Where CLIProxyAPI binary + config live
CLIPROXY_HOME=~/.renn-copilot/cliproxyapi

# CLIProxyAPI's own HTTP port (the proxy / management API)
CLIPROXY_PORT=8317
CLIPROXY_HOST=127.0.0.1

# Management key used to talk to CLIProxyAPI's Management API.
# If left empty, the backend generates one on first run and stores it
# in CLIPROXY_HOME/config.yaml under remote-management.secret-key.
CLIPROXY_MANAGEMENT_KEY=

# Pin a specific CLIProxyAPI release tag, or "latest"
CLIPROXY_VERSION=latest
