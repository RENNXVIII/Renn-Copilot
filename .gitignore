# Dependencies
node_modules/

# Environment / secrets
.env
.env.local
.env.*.local

# Compiled output (rebuilt via `npm run compile` / vscode:prepublish)
out/
dist/
build/

# Packaged extension (.vsix) -- rebuilt via `npm run package`
*.vsix

# VS Code extension test runner cache
.vscode-test/

# Logs
*.log
npm-debug.log*

# OS / editor junk
.DS_Store
Thumbs.db
.idea/
.vscode/
# ...except this repo's own launch/task config -- committed so F5 (Run
# Extension) works out of the box for anyone who opens this repo in VS Code.
!.vscode/
!.vscode/launch.json
!.vscode/tasks.json
