# Root-level ignores. Each subproject (backend/, dashboard/, extension/) also
# has its own .gitignore for build artifacts specific to that tool.

# Dependencies
node_modules/

# Environment / secrets
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# OS / editor junk
.DS_Store
Thumbs.db
.idea/
.vscode/
# ...except extension/'s launch/task config -- committed so F5 (Run Extension)
# works out of the box for anyone who opens extension/ as their workspace.
!extension/.vscode/
!extension/.vscode/launch.json
!extension/.vscode/tasks.json

# Generic build output (if ever produced at repo root)
dist/
build/
